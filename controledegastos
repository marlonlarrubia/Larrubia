];

const CHECKLIST_TRANSF = [
  { id:'reserva',  name:'Transferência — Reserva',     val:'R$ 700',  dia:'Dia 5', group:'transf' },
  { id:'invest',   name:'Transferência — Investimento', val:'R$ 300',  dia:'Dia 5', group:'transf' },
];

// ══════════════════════════════════════════
// STORAGE
// ══════════════════════════════════════════

function getExpenses() {
  try {
    return JSON.parse(localStorage.getItem('exp_' + MONTH_KEY()) || '[]');
  } catch(e) { return []; }
}

function saveExpenses(arr) {
  localStorage.setItem('exp_' + MONTH_KEY(), JSON.stringify(arr));
}

function getChecks() {
  try {
    return JSON.parse(localStorage.getItem('chk_' + MONTH_KEY()) || '{}');
  } catch(e) { return {}; }
}

function saveChecks(obj) {
  localStorage.setItem('chk_' + MONTH_KEY(), JSON.stringify(obj));
}

function getReserva() {
  return parseFloat(localStorage.getItem('reserva') || '10000');
}

function saveReserva(v) {
  localStorage.setItem('reserva', String(v));
}

// ══════════════════════════════════════════
// TABS
// ══════════════════════════════════════════

function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
  if (id === 'resumo') renderResumo();
  if (id === 'check')  renderChecklists();
}

// ══════════════════════════════════════════
// EXPENSES
// ══════════════════════════════════════════

function addExpense() {
  const desc = document.getElementById('expDesc').value.trim();
  const val  = parseFloat(document.getElementById('expVal').value);
  const cat  = document.getElementById('expCat').value;
  const date = document.getElementById('expDate').value;

  if (!desc || isNaN(val) || val <= 0) {
    document.getElementById(desc ? 'expVal' : 'expDesc').style.borderColor = '#e06060';
    setTimeout(() => {
      document.getElementById('expDesc').style.borderColor = '';
      document.getElementById('expVal').style.borderColor = '';
    }, 1200);
    return;
  }

  const expenses = getExpenses();
  expenses.unshift({
    id: Date.now(),
    desc,
    val,
    cat,
    date: date || new Date().toISOString().split('T')[0]
  });
  saveExpenses(expenses);

  document.getElementById('expDesc').value = '';
  document.getElementById('expVal').value  = '';

  renderExpenses();
  updateHeader();
}

function deleteExpense(id) {
  const expenses = getExpenses().filter(e => e.id !== id);
  saveExpenses(expenses);
  renderExpenses();
  updateHeader();
}

function fmt(v) {
  return 'R$ ' + v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2});
}

function renderExpenses() {
  const expenses = getExpenses();
  const list = document.getElementById('expenseList');

  if (expenses.length === 0) {
    list.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div>Nenhum gasto registrado ainda.<br>Use o formulário acima para começar.</div>`;
    renderCatTotals([]);
    return;
  }

  list.innerHTML = expenses.map(e => {
    const cfg = CAT_CONFIG[e.cat] || CAT_CONFIG.outros;
    const d = e.date ? new Date(e.date + 'T12:00:00').toLocaleDateString('pt-BR', {day:'2-digit',month:'short'}) : '';
    return `
      <div class="expense-item">
        <div class="exp-cat-dot" style="background:${cfg.color}"></div>
        <div class="exp-info">
          <div class="exp-name">${e.desc}</div>
          <div class="exp-meta">${cfg.label} · ${d}</div>
        </div>
        <div class="exp-val" style="color:${cfg.color}">${fmt(e.val)}</div>
        <button class="exp-del" onclick="deleteExpense(${e.id})">✕</button>
      </div>`;
  }).join('');

  renderCatTotals(expenses);
}

function renderCatTotals(expenses) {
  const totals = {};
  expenses.forEach(e => {
    totals[e.cat] = (totals[e.cat] || 0) + e.val;
  });

  const cats = Object.keys(CAT_CONFIG).filter(k => totals[k] > 0);
  if (cats.length === 0) {
    document.getElementById('catTotals').innerHTML = '';
    return;
  }

  const maxVal = Math.max(...cats.map(k => CAT_CONFIG[k].budget));

  document.getElementById('catTotals').innerHTML = cats.map(k => {
    const cfg = CAT_CONFIG[k];
    const spent = totals[k] || 0;
    const pct = Math.min((spent / cfg.budget) * 100, 100);
    const over = spent > cfg.budget;
    return `
      <div class="cat-row">
        <div class="cat-info">
          <div class="cat-name">${cfg.label}</div>
          <div class="cat-bar-track">
            <div class="cat-bar-fill" style="width:${pct}%;background:${over ? '#e06060' : cfg.color}"></div>
          </div>
        </div>
        <div class="cat-vals">
          <div class="cat-spent" style="color:${over ? '#e06060' : cfg.color}">${fmt(spent)}</div>
          <div class="cat-budget">meta ${fmt(cfg.budget)}</div>
        </div>
      </div>`;
  }).join('');
}

// ══════════════════════════════════════════
// CHECKLIST
// ══════════════════════════════════════════

function renderChecklists() {
  const checks = getChecks();
  const now = new Date().getDate();

  function renderGroup(items, containerId) {
    document.getElementById(containerId).innerHTML = items.map(item => {
      const done = !!checks[item.id];
      // overdue logic: only for items with specific days
      const overdue = !done && item.id === 'aluguel' && now > 7;
      return `
        <div class="check-item ${done ? 'done' : ''} ${overdue ? 'overdue' : ''}"
             onclick="toggleCheck('${item.id}')">
          <div class="check-box">${done ? '✓' : ''}</div>
          <div class="check-info">
            <div class="check-name">${item.name}</div>
            <div class="check-sub">${item.dia}</div>
          </div>
          <div class="check-val">${item.val}</div>
        </div>`;
    }).join('');
  }

  renderGroup(CHECKLIST_FIXOS, 'checkFixos');
  renderGroup(CHECKLIST_TRANSF, 'checkTransf');
}

function toggleCheck(id) {
  const checks = getChecks();
  checks[id] = !checks[id];
  saveChecks(checks);
  renderChecklists();
}

// ══════════════════════════════════════════
// RESERVA
// ══════════════════════════════════════════

function updateReserva() {
  const input = document.getElementById('reservaInput');
  const v = parseFloat(input.value);
  if (isNaN(v) || v < 0) return;
  saveReserva(v);
  input.value = '';
  renderResumo();
}

// ══════════════════════════════════════════
// RESUMO
// ══════════════════════════════════════════

function renderResumo() {
  const expenses = getExpenses();
  const checks   = getChecks();

  const total = expenses.reduce((s,e) => s + e.val, 0);
  const saldo = BUDGET - total;

  document.getElementById('resumoTotal').textContent = fmt(total);
  document.getElementById('resumoTotal').style.color = total > BUDGET ? '#e06060' : '#e09a50';

  // Group totals
  const alim  = expenses.filter(e => ['mercado','restaurante','delivery'].includes(e.cat)).reduce((s,e) => s+e.val, 0);
  const mor   = expenses.filter(e => e.cat === 'moradia').reduce((s,e) => s+e.val, 0);
  const trans = expenses.filter(e => ['combustivel','transporte'].includes(e.cat)).reduce((s,e) => s+e.val, 0);
  const bem   = expenses.filter(e => e.cat === 'saude').reduce((s,e) => s+e.val, 0);

  document.getElementById('resAlim').textContent  = fmt(alim);
  document.getElementById('resMor').textContent   = fmt(mor);
  document.getElementById('resTrans').textContent = fmt(trans);
  document.getElementById('resBem').textContent   = fmt(bem);

  document.getElementById('resAlim').style.color  = alim  > 2900 ? '#e06060' : '#e09a50';
  document.getElementById('resMor').style.color   = mor   > 2300 ? '#e06060' : '#5f9be0';
  document.getElementById('resTrans').style.color = trans > 1000 ? '#e06060' : '#d4b84a';
  document.getElementById('resBem').style.color   = bem   > 500  ? '#e06060' : '#50c8a8';

  // Checklist status
  const fixosDone  = CHECKLIST_FIXOS.filter(i => checks[i.id]).length;
  const transfDone = CHECKLIST_TRANSF.filter(i => checks[i.id]).length;
  document.getElementById('resCheckFixos').textContent  = `${fixosDone}/${CHECKLIST_FIXOS.length}`;
  document.getElementById('resCheckTransf').textContent = `${transfDone}/${CHECKLIST_TRANSF.length}`;
  document.getElementById('resCheckFixos').style.color  = fixosDone  === CHECKLIST_FIXOS.length  ? '#7ecb6a' : '#e09a50';
  document.getElementById('resCheckTransf').style.color = transfDone === CHECKLIST_TRANSF.length ? '#50c8a8' : '#e09a50';

  // Reserva
  const reserva = getReserva();
  const meta    = 30000;
  const pct     = Math.min((reserva / meta) * 100, 100);
  const falta   = Math.max(meta - reserva, 0);
  document.getElementById('reservaPct').textContent  = Math.round(pct) + '%';
  document.getElementById('reservaBar').style.width  = pct + '%';
  document.getElementById('reservaAtual').textContent = fmt(reserva) + ' atual';
  document.getElementById('reservaFalta').textContent = fmt(falta) + ' faltam';
}

// ══════════════════════════════════════════
// HEADER
// ══════════════════════════════════════════

function updateHeader() {
  const expenses = getExpenses();
  const total = expenses.reduce((s,e) => s + e.val, 0);
  const saldo = BUDGET - total;

  document.getElementById('hdrGasto').textContent = fmt(total);
  document.getElementById('hdrSaldo').textContent = fmt(Math.abs(saldo));
  document.getElementById('hdrSaldo').style.color = saldo >= 0 ? '#7ecb6a' : '#e06060';

  const now = new Date();
  const months = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  document.getElementById('monthBadge').textContent = months[now.getMonth()] + ' ' + now.getFullYear();
}

// ══════════════════════════════════════════
// EXPORT
// ══════════════════════════════════════════

function exportData() {
  const expenses = getExpenses();
  const checks   = getChecks();
  const reserva  = getReserva();
  const total    = expenses.reduce((s,e) => s + e.val, 0);
  const now      = new Date();
  const months   = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

  const alim  = expenses.filter(e => ['mercado','restaurante','delivery'].includes(e.cat)).reduce((s,e) => s+e.val, 0);
  const mor   = expenses.filter(e => e.cat === 'moradia').reduce((s,e) => s+e.val, 0);
  const trans = expenses.filter(e => ['combustivel','transporte'].includes(e.cat)).reduce((s,e) => s+e.val, 0);
  const bem   = expenses.filter(e => e.cat === 'saude').reduce((s,e) => s+e.val, 0);

  const fixosDone  = CHECKLIST_FIXOS.filter(i => checks[i.id]).length;
  const transfDone = CHECKLIST_TRANSF.filter(i => checks[i.id]).length;

  const catTotals = {};
  expenses.forEach(e => { catTotals[e.cat] = (catTotals[e.cat] || 0) + e.val; });

  let text = `📊 RESUMO FINANCEIRO — ${months[now.getMonth()].toUpperCase()} ${now.getFullYear()}\n`;
  text += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n`;
  text += `💰 TOTAL GASTO: ${fmt(total)} / ${fmt(BUDGET)}\n`;
  text += `📈 SALDO: ${fmt(BUDGET - total)}\n\n`;
  text += `📦 POR GRUPO:\n`;
  text += `  Alimentação: ${fmt(alim)} (meta R$ 2.900)\n`;
  text += `  Moradia: ${fmt(mor)} (meta R$ 2.300)\n`;
  text += `  Transporte: ${fmt(trans)} (meta R$ 1.000)\n`;
  text += `  Bem-estar: ${fmt(bem)} (meta R$ 500)\n\n`;
  text += `✅ CHECKLIST:\n`;
  text += `  Compromissos fixos: ${fixosDone}/${CHECKLIST_FIXOS.length}\n`;
  text += `  Transferências: ${transfDone}/${CHECKLIST_TRANSF.length}\n\n`;
  text += `🏦 RESERVA: ${fmt(reserva)} / R$ 30.000 (${Math.round((reserva/30000)*100)}%)\n\n`;
  text += `📋 TODOS OS LANÇAMENTOS:\n`;
  expenses.forEach(e => {
    const d = e.date ? new Date(e.date + 'T12:00:00').toLocaleDateString('pt-BR') : '';
    text += `  ${d} · ${e.desc} · ${fmt(e.val)} · ${CAT_CONFIG[e.cat]?.label || 'Outros'}\n`;
  });

  if (navigator.share) {
    navigator.share({ title: `Resumo ${months[now.getMonth()]}`, text }).catch(() => {});
  } else {
    navigator.clipboard?.writeText(text).then(() => {
      alert('Resumo copiado! Cole no chat para análise.');
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      alert('Resumo copiado! Cole no chat para análise.');
    });
  }
}

// ══════════════════════════════════════════
